---
import Base from '../layouts/Base.astro';
import TopBar from '../components/TopBar.astro';
import NowBox from '../components/NowBox.astro';
import Rooms from '../components/Rooms.astro';
import Ventures from '../components/Ventures.astro';
import Notes from '../components/Notes.astro';
import TravelsMap from '../components/TravelsMap.astro';
import Colophon from '../components/Colophon.astro';
---

<Base>
  <TopBar />

  <main class="max-w-[720px] mx-auto px-5 py-8">
    <!-- Hero -->
    <section class="mb-12">
      <h1 class="text-4xl sm:text-5xl mb-6">HELLO, I'M SENOTE 👋</h1>
      <p class="text-ink-soft leading-relaxed mb-4">
        I'm a dentist in Melbourne, and I'm building two small things in dental tech: <strong class="text-ink">Apollonia</strong> (a 4K camera that records what I do at work) and <strong class="text-ink">DentalScribe</strong> (an AI sidekick that writes my clinical notes so I don't have to). I grew up between Saudi Arabia, Egypt, and Australia, burned out at 23, and spent the better part of a year wandering through Latin America before coming home with a slightly different idea of what to do with my life.
      </p>
      <p class="text-ink-soft leading-relaxed">
        This little site is my garden, a place to keep notes on what I'm building, what I'm learning, and what I'm doing with the rest of my time. It grows slowly. Nothing here is finished. (That's kind of the point.)
      </p>
    </section>

    <!-- Now -->
    <NowBox />

    <!-- Rooms -->
    <section class="mt-16">
      <h2 class="text-2xl mb-6">rooms in the garden</h2>
      <Rooms />
    </section>

    <!-- Ventures -->
    <section class="mt-16">
      <h2 class="text-2xl mb-6">what i'm building</h2>
      <Ventures />
    </section>

    <!-- Notes -->
    <section class="mt-16">
      <h2 class="text-2xl mb-6">recent notes</h2>
      <Notes />
    </section>

    <!-- Travels Map -->
    <section class="mt-16">
      <h2 class="text-2xl mb-6">places i've wandered</h2>
      <TravelsMap />
    </section>

    <!-- Elsewhere -->
    <section id="elsewhere" class="mt-16">
      <h2 class="text-2xl mb-6">elsewhere on the web</h2>
      <ul class="list-none p-0 m-0 space-y-2">
        <li class="flex items-center gap-2">
          <span class="text-moss" aria-hidden="true">→</span>
          <a href="https://instagram.com/dr.senote" target="_blank" rel="noopener noreferrer">Instagram</a>
          <span class="font-chrome text-ink-faint">@dr.senote</span>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-moss" aria-hidden="true">→</span>
          <a href="https://dentalscribe.io" target="_blank" rel="noopener noreferrer">DentalScribe</a>
          <span class="font-chrome text-ink-faint">dentalscribe.io</span>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-moss" aria-hidden="true">→</span>
          <a href="https://github.com/senote" target="_blank" rel="noopener noreferrer">GitHub</a>
          <span class="font-chrome text-ink-faint">@senote</span>
        </li>
      </ul>
    </section>

    <!-- Colophon -->
    <Colophon />
  </main>
</Base>
