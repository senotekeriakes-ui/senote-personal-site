---
import { VISITED, countryFlag, totalCountries, continents, worldPercentage, remaining } from '../data/visited-countries';
import worldMapRaw from '../assets/world-map.svg?raw';

// Build the country data as JSON for the client script
const visitedJson = JSON.stringify(VISITED);

// Group countries by type for the legend chips
const lived = Object.entries(VISITED).filter(([, v]) => v.type === 'lived');
const visited = Object.entries(VISITED).filter(([, v]) => v.type === 'visited');
---

<section id="travels" class="mt-2">
  <!-- Map container -->
  <div class="world-map overflow-hidden rounded-sm border border-line-soft" set:html={worldMapRaw} />

  <!-- Tooltip (positioned by JS) -->
  <div id="map-tooltip" class="map-tooltip" aria-hidden="true"></div>

  <!-- Legend -->
  <div class="flex flex-wrap gap-4 mt-4 font-chrome text-ink-faint">
    <span class="inline-flex items-center gap-1.5">
      <span class="w-3 h-3 rounded-sm bg-berry" aria-hidden="true"></span> lived
    </span>
    <span class="inline-flex items-center gap-1.5">
      <span class="w-3 h-3 rounded-sm bg-moss" aria-hidden="true"></span> visited
    </span>
    <span class="inline-flex items-center gap-1.5">
      <span class="w-3 h-3 rounded-sm bg-paper-shade border border-line-soft" aria-hidden="true"></span> not yet
    </span>
  </div>

  <!-- Stats bar -->
  <p class="font-chrome text-ink-faint mt-3">
    {totalCountries} countries · {continents} continents · ~{worldPercentage}% of the world · {remaining}+ still to go
  </p>

  <!-- Collapsible country list -->
  <details class="mt-4">
    <summary class="font-chrome text-ink-faint cursor-pointer hover:text-moss transition-colors">
      full country list
    </summary>
    <div class="mt-3 space-y-3">
      <div>
        <p class="font-chrome text-berry mb-2 mt-0">lived</p>
        <div class="flex flex-wrap gap-2">
          {lived.map(([code, country]) => (
            <span class="inline-flex items-center gap-1 bg-paper-soft border border-line-soft rounded-sm px-2 py-1 text-sm">
              <span>{countryFlag(code)}</span>
              <span>{country.name}</span>
            </span>
          ))}
        </div>
      </div>
      <div>
        <p class="font-chrome text-moss mb-2 mt-0">visited</p>
        <div class="flex flex-wrap gap-2">
          {visited.map(([code, country]) => (
            <span class="inline-flex items-center gap-1 bg-paper-soft border border-line-soft rounded-sm px-2 py-1 text-sm">
              <span>{countryFlag(code)}</span>
              <span>{country.name}</span>
            </span>
          ))}
        </div>
      </div>
    </div>
  </details>
</section>

<script define:vars={{ visitedJson }}>
  // Apply visited/lived classes to map paths
  const visited = JSON.parse(visitedJson);
  const tooltip = document.getElementById('map-tooltip');

  Object.entries(visited).forEach(([code, info]) => {
    const path = document.getElementById(code);
    if (path) {
      path.classList.add(info.type);
    }
  });

  // Tooltip logic
  document.querySelectorAll('.world-map path.visited, .world-map path.lived').forEach((path) => {
    const code = path.id;
    const info = visited[code];
    if (!info || !tooltip) return;

    path.addEventListener('mouseenter', (e) => {
      tooltip.textContent = `${info.name} (${info.type})`;
      tooltip.classList.add('visible');
    });

    path.addEventListener('mousemove', (e) => {
      tooltip.style.left = e.clientX + 12 + 'px';
      tooltip.style.top = e.clientY - 8 + 'px';
    });

    path.addEventListener('mouseleave', () => {
      tooltip.classList.remove('visible');
    });
  });
</script>
