---
import { ROOMS } from '../data/rooms';

const statusColors = {
  evergreen: 'text-moss',
  growing: 'text-amber-600',
  seedling: 'text-berry',
} as const;
---

<section id="rooms">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {ROOMS.map((room) => (
      <a
        href={`#${room.slug}`}
        class="group flex gap-3 p-4 rounded-sm border border-transparent no-underline transition-all duration-150 hover:translate-x-0.5 hover:bg-paper-soft hover:border-line-soft"
      >
        <span class="text-xl shrink-0" aria-hidden="true">{room.emoji}</span>
        <div class="min-w-0">
          <div class="flex items-baseline gap-2">
            <span class="text-lg font-semibold uppercase">
              {room.name}
            </span>
            <span class={`font-chrome ${statusColors[room.status]}`}>
              {room.status}
            </span>
          </div>
          <p class="text-sm text-ink-soft mt-0.5 mb-0 leading-snug">{room.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>
